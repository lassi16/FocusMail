# Example environment variables for deployment

# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis (Upstash or other managed Redis)
REDIS_URL=redis://:password@host:6379

# LLM / API keys
GROQ_API_KEY=

# Gmail OAuth (set from Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# Vector DB (optional)
PINECONE_API_KEY=
PINECONE_ENV=

# Frontend
FRONTEND_URL=https://your-frontend.example.com

# Scheduler
SYNC_INTERVAL_MINUTES=10
